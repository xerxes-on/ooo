<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- SAMPLE MODEL VIEWS                                           -->
    <!-- ============================================================ -->

    <!-- List View -->
    <record id="x_custom_sample_view_list" model="ir.ui.view">
        <field name="name">x_custom.sample.view.list</field>
        <field name="model">x_custom.sample</field>
        <field name="arch" type="xml">
            <list string="Samples" decoration-muted="state == 'cancelled'">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date"/>
                <field name="amount" sum="Total"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'confirmed'" decoration-success="state == 'done'" decoration-danger="state == 'cancelled'"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="x_custom_sample_view_form" model="ir.ui.view">
        <field name="name">x_custom.sample.view.form</field>
        <field name="model">x_custom.sample</field>
        <field name="arch" type="xml">
            <form string="Sample">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" string="Mark Done" type="object" class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state not in ('cancelled',)"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- Add stat buttons here -->
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Enter name..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="General Information">
                            <field name="partner_id"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="date"/>
                        </group>
                        <group string="Financial">
                            <field name="amount"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Enter description..."/>
                        </page>
                        <page string="Other Info" name="other_info">
                            <group>
                                <field name="active"/>
                                <field name="sequence"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="x_custom_sample_view_kanban" model="ir.ui.view">
        <field name="name">x_custom.sample.view.kanban</field>
        <field name="model">x_custom.sample</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="state"/>
                <field name="partner_id"/>
                <field name="amount"/>
                <field name="user_id"/>
                <templates>
                    <t t-name="card">
                        <field name="name" class="fw-bold fs-5"/>
                        <field name="partner_id"/>
                        <div class="d-flex justify-content-between">
                            <field name="amount" widget="monetary"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="x_custom_sample_view_search" model="ir.ui.view">
        <field name="name">x_custom.sample.view.search</field>
        <field name="model">x_custom.sample</field>
        <field name="arch" type="xml">
            <search string="Search Samples">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <separator/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="filter_my_records" string="My Records" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter name="filter_archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="groupby_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="groupby_partner" string="Partner" context="{'group_by': 'partner_id'}"/>
                    <filter name="groupby_user" string="Responsible" context="{'group_by': 'user_id'}"/>
                    <filter name="groupby_date" string="Date" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- ACTIONS                                                      -->
    <!-- ============================================================ -->

    <record id="x_custom_sample_action" model="ir.actions.act_window">
        <field name="name">Samples</field>
        <field name="res_model">x_custom.sample</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="x_custom_sample_view_search"/>
        <field name="context">{'search_default_filter_my_records': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sample record!
            </p>
            <p>
                This is a template module for custom Odoo development.
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- MENUS                                                        -->
    <!-- ============================================================ -->

    <!-- Top Menu -->
    <menuitem
        id="x_custom_menu_root"
        name="Custom Odoo"
        sequence="100"
        web_icon="custom_odoo,static/description/icon.png"/>

    <!-- Sub Menu -->
    <menuitem
        id="x_custom_menu_samples"
        name="Samples"
        parent="x_custom_menu_root"
        sequence="10"/>

    <!-- Action Menu -->
    <menuitem
        id="x_custom_menu_sample_list"
        name="Samples"
        parent="x_custom_menu_samples"
        action="x_custom_sample_action"
        sequence="10"/>

</odoo>
